# --- Z.AI / GLM ---
# Set these to use GLM-4.7-flash. Get key from Z.AI.
LLM_BASE_URL=https://api.z.ai/api/paas/v4/
LLM_API_KEY=your-Z.AI-api-key
LLM_MODEL=glm-4.7-flash

# --- HF Router (for AI Tutor) ---
# Get token from https://huggingface.co/settings/tokens
# HF_ROUTER_API_KEY=your_hf_token
# HF_ROUTER_MODEL=MiniMaxAI/MiniMax-M2.7:fireworks-ai
# HF_ROUTER_BASE_URL=https://router.huggingface.co/v1

# --- RAG (embedding and reranker) ---
# EMBEDDING_MODEL=all-MiniLM-L6-v2
# RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
# Use PostgreSQL pgvector for dense semantic retrieval. Set false to fall back to local NumPy cache.
# RAG_USE_PGVECTOR=true
# In production, fail startup if pgvector cannot be used instead of silently falling back.
# RAG_REQUIRE_PGVECTOR=true

# --- Database & Auth ---
# PostgreSQL connection URL (async)
# Local example (with pgvector Docker):
#   postgresql+asyncpg://csrag:csrag@localhost:5432/cs_rag
# DigitalOcean Managed PostgreSQL (pgvector extension must be enabled):
#   postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DATABASE?ssl=require
# Supabase / Neon:
#   postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DATABASE
# DATABASE_URL=postgresql+asyncpg://csrag:csrag@localhost:5432/cs_rag

# JWT settings for auth (still used for our internal tokens after Clerk exchange)
# JWT_SECRET=your-jwt-secret
# JWT_ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=30
# REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Clerk Auth ---
# Get keys from Clerk Dashboard > API Keys
# VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
# CLERK_SECRET_KEY=sk_test_...
# CLERK_JWKS_URL=https://api.clerk.com/v1/jwks
# Optional hardening: enforce expected issuer/audience claims
# CLERK_ISSUER=https://clerk.your-domain.com
# CLERK_AUDIENCE=your-api-audience

# --- Runtime Session Bounds (DoS safety) ---
# Conversation memory sessions kept in app memory
# CONVERSATION_SESSION_TTL_MINUTES=120
# CONVERSATION_SESSION_MAX=2000
# Quiz review sessions kept in app memory
# QUIZ_SESSION_TTL_MINUTES=180
# QUIZ_SESSION_MAX=2000

# --- CORS / Frontend origins ---
# Comma-separated list of allowed origins for the API.
# Local dev default is http://localhost:5173 if unset.
# Production examples:
#   BACKEND_CORS_ORIGINS=https://your-frontend.vercel.app
#   BACKEND_CORS_ORIGINS=https://your-frontend.ondigitalocean.app
# To temporarily allow all origins (no credentials):
#   BACKEND_CORS_ORIGINS=*
# BACKEND_CORS_ORIGINS=http://localhost:5173

# --- Deployment ---
# APP_ENV=development
# For DO App Platform, set APP_ENV=production and ensure DATABASE_URL is provided.
